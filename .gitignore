# macOS
.DS_Store

# 環境變數與機密
.env
.env.*
*.local

# 日誌
*.log
logs/

# 相依套件 / 建置產物(依實際技術棧再調整)
node_modules/
dist/
build/
out/
target/
bin/
*.exe

# 編輯器 / IDE
.vscode/
.idea/
*.swp

# 暫存
tmp/
.cache/

# 密鑰與憑證(絕不進 repo)
*.secret
secret.txt
token.txt
*.pem
.cloudflared/

# Go 編譯產物
/server/app-tunnel-proxy
/server/app-tunnel-proxy-*

# Python 編譯產物(框架 skill 執行時生成)
__pycache__/
*.pyc
.venv/

# Claude Code 框架 runtime state(session/hook/sync 執行時生成,絕不進 repo)
# 來源:sync_exclude_manifest.GITIGNORE_EXPECTED(SOT)+ gitignore-check hook
# 背景:PC-019 死循環——runtime state 被 git tracked 會造成 dirty tree 阻擋 worktree fork
.claude/.pytest_cache/
.claude/.sync-conflicts/
.claude/.sync-state.json
.claude/.version-release.yaml
.claude/.zhtw-mcp-skip
.claude/ARCHITECTURE_REVIEW_REQUIRED
.claude/PM_INTERVENTION_REQUIRED
.claude/TASK_AVOIDANCE_FIX_MODE
.claude/analyses/
.claude/dispatch-active.json
.claude/dispatch-active.lock
.claude/handoff/
.claude/hook-logs/
.claude/hook-state/
.claude/hooks/hook-logs/
.claude/migration-backups/
.claude/plans/
.claude/pm-status.json
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/state/
.claude/sync-preserve.yaml
.claude/worktrees/

# 測試覆蓋率報告
coverage/
